PORT=3000
NODE_ENV=development
DATABASE_PATH=./data/otp-auth.db

# Generate a long random value for deployments; do not reuse this example value.
OTP_SECRET=replace-with-a-long-random-secret-at-least-32-characters
OTP_EXPIRY_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_MAX_SENDS_PER_WINDOW=5
OTP_RATE_WINDOW_MINUTES=15
SESSION_EXPIRY_HOURS=12

# Use mock to demonstrate the application without sending real SMS.
SMS_DRIVER=mock
SHOW_MOCK_OTP=true

# Reserved for the GSM modem transport after hardware details are confirmed.
GSM_DEVICE_PATH=/dev/ttyUSB0
GSM_BAUD_RATE=115200
